# ---------------------------------------------------------------------------
# SAM3 Bolt Marking Detector — environment configuration
# Copy this file to .env and adjust values for your setup.
# ---------------------------------------------------------------------------

# ── Server (web_api.py) ────────────────────────────────────────────────────

# Project root (contains models/, data/, src/)
# BOLT_MARKING_ROOT=/path/to/sam3_skill

# SAM3 code directory (must contain sam3/model_builder.py)
SAM3_ROOT=/udat/sam/sam3

# SAM3 model checkpoint
# CHECKPOINT=models/sam3.pt

# RandomForest feature judger model
# FEATURE_MODEL=models/feature_judger/random_forest_final.joblib

# Inference device: cuda or cpu
DEVICE=cuda

# API server bind address & port
HOST=0.0.0.0
PORT=8004

# ── Client (api_client_example.py) ────────────────────────────────────────

# API base URL (used by the example client & Sam3Client class)
API_BASE_URL=http://localhost:8004

# Default image path for single-image demos
# IMAGE_PATH=data/images/loose/sample.jpg

# Default image URL for URL-based detection
# IMAGE_URL=https://example.com/bolt.jpg

# Default directory for batch demos
# BATCH_DIR=data/images/normal
